# ============================================================
# ISRO AQI & HCHO Hotspot Platform — Backend Environment
# Copy this file to .env and fill in real values for production.
# ============================================================

# ---- General ----
APP_NAME="ISRO AQI & HCHO Hotspot Platform"
APP_VERSION="1.0.0"
DEBUG=false

# DEV_MODE: Set to true to use synthetic mock data (no DB/COG required)
DEV_MODE=true

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ---- Database ----
# PostgreSQL with PostGIS (for production)
DATABASE_URL="postgresql+asyncpg://aqi_user:aqi_pass@localhost:5432/aqi_hcho_db"

# ---- COG Storage ----
# Absolute path to the root directory containing COG sub-directories:
#   <COG_BASE_PATH>/aqi/   ← AQI GeoTIFFs
#   <COG_BASE_PATH>/hcho/  ← HCHO GeoTIFFs
#   <COG_BASE_PATH>/fire/  ← Fire GeoTIFFs
COG_BASE_PATH=../../data/cogs

# ---- Redis (async export jobs) ----
REDIS_URL="redis://localhost:6379/0"
